              "summary": "{\n  \"name\": \"df\",\n  \"rows\": 8560,\n  \"fields\": [\n    {\n      \"column\": \"id\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 305401,\n        \"min\": 2,\n        \"max\": 1472638,\n        \"num_unique_values\": 8021,\n        \"samples\": [\n          4553,\n          109,\n          15601\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"title\",\n      \"properties\": {\n        \"dtype\": \"string\",\n        \"num_unique_values\": 7784,\n        \"samples\": [\n          \"Hidden Kisses\",\n          \"Dungeons & Dragons: Honor Among Thieves\",\n          \"For the Birds\"\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"overview\",\n      \"properties\": {\n        \"dtype\": \"string\",\n        \"num_unique_values\": 8012,\n        \"samples\": [\n          \"An Algerian man's life-long dream finally comes true when he receives an invitation to take his cow Jacqueline to the Paris International Agriculture Fair.\",\n          \"In the third and final episode of the trilogy, Fant\\u00f4mas imposes a head tax on the rich, threatening to kill those who do not comply.\",\n          \"As the sole survivor of a horrendous and rather mysterious accident, teenage Mitsuko's day is off to a bad start. An unstoppable force of nature, a doomed field trip, and a strange case of amnesia easily coexist in a bizarre parallel universe, where a desperate Mitsuko is always on the run from something inexplicable, intangible, and utterly deadly. However, amid piles of fresh corpses, mounds of scorching bullet shells, and rivulets of fragrant adolescent blood, Mitsuko must fight to stay alive, before her already messed-up day becomes even stranger. But one question still remains: who or what is the enemy?\"\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"release_date\",\n      \"properties\": {\n        \"dtype\": \"object\",\n        \"num_unique_values\": 5498,\n        \"samples\": [\n          \"2006-09-01\",\n          \"1974-04-12\",\n          \"2011-04-09\"\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"popularity\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 12.278585387248354,\n        \"min\": 0.011,\n        \"max\": 698.6814,\n        \"num_unique_values\": 7780,\n        \"samples\": [\n          3.1089,\n          5.8093,\n          10.3269\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"vote_average\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.5592287970823003,\n        \"min\": 5.98,\n        \"max\": 8.716,\n        \"num_unique_values\": 2059,\n        \"samples\": [\n          6.772,\n          7.501,\n          6.75\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"vote_count\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 3544,\n        \"min\": 300,\n        \"max\": 39076,\n        \"num_unique_values\": 3422,\n        \"samples\": [\n          11884,\n          3681,\n          470\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"
