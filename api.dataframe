 \"properties\": {\n        \"dtype\": \"object\",\n        \"num_unique_values\": 20,\n        \"samples\": [\n          \"1994-09-23\",\n          \"1990-09-12\",\n          \"1966-12-23\"\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"popularity\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 12.004329917834252,\n        \"min\": 0.0125,\n        \"max\": 51.9612,\n        \"num_unique_values\": 20,\n        \"samples\": [\n          38.3467,\n          19.8633,\n          18.9398\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"vote_average\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.07285333139079384,\n        \"min\": 8.444,\n        \"max\": 8.716,\n        \"num_unique_values\": 17,\n        \"samples\": [\n          8.716,\n          8.688,\n          8.543\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"vote_count\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 10938,\n        \"min\": 301,\n        \"max\": 39076,\n        \"num_unique_values\": 20,\n        \"samples\": [\n          29886,\n          14091,\n          9470\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"
